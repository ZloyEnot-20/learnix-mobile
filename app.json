{
  "expo": {
    "name": "IELTS Student",
    "slug": "ielts-student",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "ielts",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#C8102E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ielts.student"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#C8102E"
      },
      "package": "com.ielts.student"
    },
    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": "Allow IELTS Student to record your speaking answers."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
